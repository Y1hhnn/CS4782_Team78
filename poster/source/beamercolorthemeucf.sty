% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

% Color Palette
% From https://news.uchicago.edu/sites/default/files/attachments/_uchicago.identity.guidelines.pdf
% Primary
\definecolor{maroon}{HTML}{B31B1B}      % cornell-red: main theme color
\definecolor{darkgray}{HTML}{233D4D}    % charcoal-blue: dark contrast
\definecolor{lightgray}{HTML}{FFF3EA}   % very light warm background

% Secondary
\definecolor{yellow}{HTML}{FCCA46}      % golden-pollen
\definecolor{orange}{HTML}{FE7F2D}      % pumpkin-spice
\definecolor{red}{HTML}{FE7F2D}         % pumpkin-spice
\definecolor{lightgreen}{HTML}{A1C181}  % muted-olive
\definecolor{darkgreen}{HTML}{619B8A}   % seagrass
\definecolor{blue}{HTML}{233D4D}        % charcoal-blue
\definecolor{violet}{HTML}{233D4D}      % charcoal-blue
\definecolor{black}{RGB}{0, 0, 0}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=maroon}
% Headline
\setbeamercolor{headline rule}{bg=red}
\setbeamercolor{headline}{fg=white,bg=maroon}

\setbeamercolor{block title}{fg=white,bg=maroon}

\setbeamercolor{block alerted title}{fg=white,bg=darkgray}

% Alert Block
\setbeamercolor{block alerted title}{fg=black,bg=lightgray}
\setbeamercolor{block alerted separator}{bg=black}
\setbeamercolor{block alerted body}{fg=black,bg=lightgray}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=darkgray}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
\setbeamertemplate{bibliography entry article}{}
\setbeamertemplate{bibliography entry title}{}
\setbeamertemplate{bibliography entry location}{}
\setbeamertemplate{bibliography entry note}{}